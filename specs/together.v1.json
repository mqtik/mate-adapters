{
  "schemaVersion": 1,
  "id": "together",
  "name": "Together AI",
  "version": 1,
  "minAppVersion": "0.0.0",
  "minDriverVersion": 0,
  "description": "Together AI OpenAI-compatible Chat Completions API. The models catalog is maintained in mate-adapters; unknown model ids default to text-only until their modalities are declared.",
  "binaryName": "http-chat-completions",
  "installInstructions": "Set TOGETHER_API_KEY. Optionally set MATE_TOGETHER_CHAT_ENDPOINT to use a compatible Together endpoint.",
  "spawn": {
    "command": "http-chat-completions",
    "args": [],
    "oneShot": false,
    "loginShell": false,
    "workingDir": "{cwd}"
  },
  "transport": {
    "kind": "http-chat-completions",
    "endpoint": "https://api.together.ai/v1/chat/completions",
    "endpointEnv": "MATE_TOGETHER_CHAT_ENDPOINT",
    "apiKeyEnv": "TOGETHER_API_KEY",
    "headers": {
      "X-Mate-Adapter": "together"
    },
    "sseDefaultEvent": "chat.completion.chunk",
    "sseDoneEvent": "chat.completion.done"
  },
  "encoding": {
    "mode": "template",
    "framing": "json",
    "attachments": "openaiChatCompletions",
    "modeInstructions": {
      "plan": "You are in Plan mode. Do not make changes or invoke mutating tools. Analyze the request, return a concise numbered implementation plan, and wait for explicit approval before implementation."
    },
    "userMessage": {
      "template": {
        "model": "{model}",
        "stream": true,
        "messages": [
          {
            "role": "user",
            "content": [
              {
                "type": "text",
                "text": "{prompt}"
              }
            ]
          }
        ]
      }
    }
  },
  "parsing": {
    "framing": "sse",
    "protocol": "chat-completions",
    "discriminator": "type",
    "pluginFallback": false,
    "rules": [
      {
        "match": {
          "equals": "chat.completion.chunk"
        },
        "emit": "streamEvent"
      },
      {
        "match": {
          "equals": "chat.completion.done"
        },
        "emit": "streamEvent"
      },
      {
        "match": {
          "equals": "error"
        },
        "emit": "streamEvent"
      }
    ],
    "reducers": [
      {
        "match": {
          "on": "type",
          "equals": "chat.completion.chunk"
        },
        "emit": "textDelta",
        "fields": {
          "text": "choices[].delta.content"
        }
      },
      {
        "match": {
          "on": "type",
          "equals": "chat.completion.done"
        },
        "emit": "turnEnd"
      },
      {
        "match": {
          "on": "type",
          "equals": "error"
        },
        "emit": "error",
        "fields": {
          "message": "message"
        }
      }
    ]
  },
  "models": [
    {
      "id": "meta-llama/Llama-4-Maverick-17B-128E-Instruct-FP8",
      "label": "Llama 4 Maverick",
      "inputModalities": [
        "text",
        "image"
      ]
    },
    {
      "id": "openai/gpt-oss-20b",
      "label": "GPT-OSS 20B",
      "inputModalities": [
        "text"
      ],
      "unsupportedImageAttachmentMessage": "This model does not support image attachments. Switch models to send images."
    },
    {
      "id": "*",
      "label": "Unknown Together model",
      "hidden": true,
      "inputModalities": [
        "text"
      ],
      "unsupportedImageAttachmentMessage": "This model does not support image attachments. Switch models to send images."
    }
  ],
  "capabilities": {
    "nativeResume": false,
    "perTurnSettings": true,
    "rawTextOutput": false,
    "permissionMetadata": "none",
    "readiness": "immediate"
  },
  "timeouts": {
    "readinessTimeoutMs": 30000,
    "wedgeTimeoutMs": 180000
  }
}
