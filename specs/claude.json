  "capabilities": {
    "nativeResume": true,
    "forkSession": true,
    "perTurnSettings": false,
    "midSessionModeSwitch": true,
    "nativeSkills": true,
    "requiresClientEncoding": false,
    "rawTextOutput": false,
    "instructionsFileName": "CLAUDE.md",
    "globalConfigDir": ".claude",
    "projectConfigDir": ".claude",
    "nextTurnQueue": true,
    "permissionMetadata": "rich"
  },
  "timeouts": {
    "noClientMs": 1800000,
    "inactiveMs": 7200000,
    "spawnFastFailMs": 10000,
    "resumeHistoryMaxChars": 20000
  },
  "codePlugin": {
    "kind": "bundled",
    "driverId": "claude",
    "minDriverVersion": 0,
    "delegates": [
      "parseStreamEvent",
      "attachments",
      "btw"
