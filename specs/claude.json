    "createTools": ["TaskCreate"],
    "updateTools": ["TaskUpdate"],
    "collectionFields": ["todos", "tasks"],
    "subjectFields": ["content", "subject", "title", "description"],
    "idFields": ["taskId", "id", "task_id"],
    "statusFields": ["status"]
