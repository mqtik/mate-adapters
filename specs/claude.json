{
  "schemaVersion": 1,
  "id": "claude",
  "name": "Claude Code",
  "version": 5,
  "minAppVersion": "0.0.0",
  "minDriverVersion": 0,
  "icon": "assets/icons/claude.svg",
  "description": "Anthropic's Claude Code CLI (stream-json).",
  "binaryName": "claude",
  "installInstructions": "Install: npm install -g @anthropic-ai/claude-code",
  "spawn": {
    "oneShot": false,
    "loginShell": true,
    "workingDir": "{cwd}",
    "oneShotArgs": [
      "--print",
      "-p",
      "{prompt}"
    ],
    "args": [
      "--input-format",
      "stream-json",
      "--output-format",
      "stream-json",
      "--print",
      {
        "flag": "--permission-prompt-tool",
        "value": "stdio"
      },
      "--verbose",
      "--include-partial-messages",
      "--settings",
      "{\"showThinkingSummaries\":true}",
      {
        "flag": [
          "--resume"
        ],
        "value": "{conversationId}",
        "when": {
          "var": "isResume",
          "op": "eq",
          "value": "true"
        }
      },
      {
        "flag": "--fork-session",
        "when": {
          "var": "forkSession",
          "op": "eq",
          "value": "true"
        }
      },
      {
        "flag": [
          "--model"
        ],
        "value": "{model}",
        "when": {
          "var": "model",
          "op": "set"
        }
      },
      {
        "flag": [
          "--effort"
        ],
        "value": "{effort}",
        "when": {
          "var": "effort",
          "op": "set"
        },
        "validValues": [
          "low",
          "medium",
          "high",
          "xhigh",
          "max"
        ]
      },
      {
        "flag": [
          "--permission-mode"
        ],
        "value": "plan",
        "when": {
          "var": "autonomyMode",
          "op": "eq",
          "value": "plan"
        }
      },
      {
        "flag": [
          "--permission-mode"
        ],
        "value": "acceptEdits",
        "when": {
          "var": "autonomyMode",
          "op": "eq",
          "value": "auto"
        }
      },
      {
        "flag": "--dangerously-skip-permissions",
        "when": {
          "var": "autonomyMode",
          "op": "eq",
          "value": "bypass"
        }
      },
      {
        "flag": [
          "--max-turns"
        ],
        "value": "{maxTurns}",
        "when": {
          "var": "maxTurns",
          "op": "set"
        }
      },
      {
        "flag": [
          "--append-system-prompt"
        ],
        "value": "{systemPrompt}",
        "when": {
          "var": "appendSystemPrompt",
          "op": "eq",
          "value": "true"
        }
      },
      {
        "flag": [
          "--system-prompt"
        ],
        "value": "{systemPrompt}",
        "when": {
          "var": "appendSystemPrompt",
          "op": "ne",
          "value": "true"
        }
      },
      {
        "flag": [
          "--mcp-config"
        ],
        "value": "{mcpConfigPath}",
        "when": {
          "var": "mcpConfigPath",
          "op": "set"
        }
      },
      {
        "flag": [
          "--disallowedTools"
        ],
        "value": "{item}",
        "repeatFor": "disallowedTools"
      }
    ],
    "envFilters": {
      "removeNames": [
        "CLAUDECODE"
      ],
      "removePrefixes": [
        "Malloc"
      ],
      "prependPathDirs": [
        "{bundledBinDir}"
      ],
      "passThrough": [
        "PATH",
        "HOME",
        "LANG",
        "TERM",
        "USER",
        "SHELL"
      ]
    }
  },
  "encoding": {
    "mode": "template",
    "framing": "ndjson",
    "attachments": "plugin",
    "userMessage": {
      "template": {
        "type": "user",
        "message": {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "{prompt}"
            }
          ]
        }
      }
    },
    "controlResponse": {
      "template": {
        "type": "control_response",
        "request_id": "{requestId}",
        "response": {
          "behavior": "{behavior}",
          "updatedInput": "{updatedInput}"
        }
      }
    }
  },
  "parsing": {
    "framing": "ndjson",
    "protocol": "stream-json",
    "discriminator": "type",
    "pluginFallback": true,
    "rules": [
      {
        "match": {
          "all": [
            {"field": "type", "equals": "system"},
            {"field": "subtype", "equals": "thinking_tokens"}
          ]
        },
        "emit": "ignore"
      },
      {
        "match": {
          "all": [
            {"field": "type", "equals": "stream_event"},
            {"field": "event.type", "equals": "message_delta"}
          ]
        },
        "emit": "ignore"
      },
      {
        "match": {
          "all": [
            {"field": "type", "equals": "stream_event"},
            {"field": "event.delta.type", "equals": "signature_delta"}
          ]
        },
        "emit": "ignore"
      },
      {
        "match": {
          "equals": "message_start"
        },
        "emit": "turnStart"
      },
      {
        "match": {
          "equals": "rate_limit_event"
        },
        "emit": "ignore"
      },
      {
        "match": {
          "equals": "content_block_stop"
        },
        "emit": "plugin",
        "stateful": true
      },
      {
        "match": {
          "equals": "control_request"
        },
        "emit": "permission",
        "fields": {
          "requestId": "request_id",
          "subtype": "request.subtype",
          "toolName": "request.tool_name",
          "input": "request.input",
          "toolUseId": "request.tool_use_id",
          "suggestions": {"coalesce": ["request.permission_suggestions", "request.suggestions"]}
        }
      },
      {
        "match": {
          "equals": "result"
        },
        "emit": "result",
        "fields": {
          "cost": "total_cost_usd",
          "stop": "subtype"
        }
      },
      {
        "match": {
          "equals": "message_stop"
        },
        "emit": "turnEnd"
      },
      {
        "match": {
          "equals": "system"
        },
        "emit": "system"
      },
      {
        "match": {
          "equals": "assistant"
        },
        "emit": "assistant"
      },
      {
        "match": {
          "equals": "user"
        },
        "emit": "user"
      },
      {
        "match": {
          "equals": "stream_event"
        },
        "emit": "streamEvent"
      },
      {
        "match": {
          "equals": "error"
        },
        "emit": "streamEvent"
      },
      {
        "match": {
          "equals": "control_cancel_request"
        },
        "emit": "controlCancel"
      }
    ],
    "_comment": "Rules classify stream-json frames and known non-rendering telemetry. Reducers normalize message/content-block lifecycle plus canonical assistant snapshots. Permission/review paths are declared in the control rule; only process transport and background transcript tailing remain codePlugin behavior.",
    "reducers": [
      {
        "match": {
          "on": "event.type",
          "equals": "message_start"
        },
        "emit": "turnStart"
      },
      {
        "match": {
          "on": "type",
          "equals": "assistant"
        },
        "emit": "messageDone",
        "fields": {
          "text": {
            "contentBlockText": {
              "path": "message.content",
              "type": "text",
              "field": "text",
              "join": "\n"
            }
          }
        }
      },
      {
        "match": {
          "all": [
            {
              "on": "event.type",
              "equals": "content_block_start"
            },
            {
              "on": "event.content_block.type",
              "equals": "tool_use"
            }
          ]
        },
        "setState": {
          "activeToolId": {
            "path": "event.content_block.id"
          }
        },
        "emit": "toolStart",
        "fields": {
          "id": "event.content_block.id",
          "name": "event.content_block.name",
          "input": "event.content_block.input"
        }
      },
      {
        "match": {
          "all": [
            {
              "on": "event.type",
              "equals": "content_block_delta"
            },
            {
              "on": "event.delta.type",
              "equals": "text_delta"
            }
          ]
        },
        "emit": "textDelta",
        "fields": {
          "text": "event.delta.text"
        }
      },
      {
        "match": {
          "all": [
            {
              "on": "event.type",
              "equals": "content_block_delta"
            },
            {
              "on": "event.delta.type",
              "equals": "thinking_delta"
            }
          ]
        },
        "emit": "thinkingDelta",
        "fields": {
          "text": "event.delta.thinking"
        }
      },
      {
        "match": {
          "all": [
            {
              "on": "event.type",
              "equals": "content_block_delta"
            },
            {
              "on": "event.delta.type",
              "equals": "input_json_delta"
            }
          ]
        },
        "emit": "toolDelta",
        "fields": {
          "partialJson": "event.delta.partial_json"
        }
      },
      {
        "match": {
          "on": "event.type",
          "equals": "content_block_stop"
        },
        "whenState": {
          "activeToolId": "$set"
        },
        "emit": "toolDone",
        "fields": {
          "toolId": {
            "state": "activeToolId"
          },
          "terminal": {
            "value": false
          }
        },
        "setState": {
          "activeToolId": null
        }
      },
      {
        "match": {
          "on": "event.type",
          "equals": "message_stop"
        },
        "emit": "turnEnd"
      }
    ]
  },
  "tools": {
