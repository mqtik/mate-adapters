        "SearchText",
        "semantic_search",
        "Glob",
        "file_search",
        "FindFiles",
        "glob",
        "list_directory",
        "ReadFolder"
      ],
      "agent": [
        "Agent",
        "read_agent",
        "write_agent",
        "codebase_investigator"
      ],
      "web": [
        "WebSearch",
        "web_search",
        "google_web_search",
        "GoogleSearch",
        "WebFetch",
        "web_fetch"
      ],
      "plan": [
        "EnterPlanMode",
