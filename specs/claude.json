      "task": [
        "TodoWrite",
        "WriteTodos",
        "write_todos",
        "TaskCreate",
        "TaskUpdate",
        "TaskList",
        "TaskGet",
        "TodoRead"
      ]
    },
    "aliases": {
      "Write": [
        "write_file",
        "WriteFile"
      ],
      "Read": [
        "read_file",
        "show_file",
        "ReadFile",
        "ReadManyFiles"
      ],
      "Bash": [
        "shell",
        "run_in_terminal",
        "run_shell_command",
        "Shell",
        "session.shell.exec"
      ]
    },
    "display": {
      "Read": {
        "friendlyName": "Read file",
        "labelTemplate": "Read {detail}",
        "detailFields": [
          "file_path",
          "path",
          "filePath"
        ]
      },
      "Write": {
        "friendlyName": "Write file",
        "labelTemplate": "Write {detail}",
        "detailFields": [
          "file_path",
          "path"
        ]
      },
      "Edit": {
        "friendlyName": "Edit file",
        "labelTemplate": "Edit {detail}",
        "detailFields": [
          "file_path",
          "path"
        ]
      },
      "Bash": {
        "friendlyName": "Run command",
        "labelTemplate": "{detail}",
        "detailFields": [
          "command",
          "cmd"
        ]
      },
      "Grep": {
        "friendlyName": "Search",
        "labelTemplate": "Search \"{detail}\"",
        "detailFields": [
          "pattern",
          "query"
        ]
      },
      "Glob": {
        "friendlyName": "Find files",
        "labelTemplate": "Find {detail}",
        "detailFields": [
          "pattern",
          "query"
        ]
      },
      "Agent": {
        "friendlyName": "Agent",
        "labelTemplate": "Agent: {detail}",
        "detailFields": [
          "description",
          "prompt"
        ]
      },
      "WebSearch": {
        "friendlyName": "Web search",
        "labelTemplate": "Search \"{detail}\"",
        "detailFields": [
          "query"
        ]
      },
      "WebFetch": {
        "friendlyName": "Fetch URL",
        "labelTemplate": "Fetch {detail}",
        "detailFields": [
          "url"
        ]
      }
    },
    "shellWrappers": [
      "/usr/bin/env zsh -l -c ",
      "/usr/bin/env bash -l -c ",
      "/usr/bin/env sh -l -c ",
      "/usr/bin/env zsh -lc ",
      "/usr/bin/env bash -lc ",
      "/usr/bin/env sh -lc ",
      "/bin/zsh -l -c ",
      "/bin/bash -l -c ",
      "/bin/sh -l -c ",
      "/bin/zsh -lc ",
      "/bin/bash -lc ",
      "/bin/sh -lc ",
      "zsh -l -c ",
      "bash -l -c ",
      "sh -l -c ",
      "zsh -lc ",
      "bash -lc ",
      "sh -lc ",
      "/bin/zsh -c ",
      "/bin/bash -c ",
      "/bin/sh -c ",
      "zsh -c ",
      "bash -c ",
      "sh -c "
    ],
    "semanticShellPatterns": [
      {
        "commands": [
          "cat",
          "sed",
          "head",
          "tail",
          "nl",
          "less",
          "more"
        ],
        "toolName": "Read"
      },
      {
        "commands": [
          "rg",
          "grep",
          "ag"
        ],
        "toolName": "Grep"
      },
      {
        "commands": [
          "find",
          "fd",
          "ls",
          "tree"
        ],
        "toolName": "list_directory"
      }
    ]
  },
  "tasks": {
