      "command": "/btw",
      "description": "Ask a side question without interrupting",
      "action": "btw",
      "promptStarter": "/btw ",
      "requiresActiveConversation": true
    },
    {
      "command": "/clear",
      "description": "Clear conversation, keep session",
      "action": "clear"
    },
    {
      "command": "/new",
      "description": "Start completely fresh",
      "action": "new"
    },
    {
      "command": "/rewind",
      "description": "Rewind to last user message",
      "action": "rewind"
    },
    {
      "command": "/fork",
      "description": "Fork into a new tab",
      "action": "fork",
      "requiresActiveConversation": true
