{
  "schemaVersion": 1,
  "id": "openai-compatible-chat",
  "name": "OpenAI-Compatible Chat Completions",
  "version": 1,
  "minAppVersion": "0.0.0",
  "minDriverVersion": 0,
  "description": "OpenAI Chat Completions API over HTTP/SSE. Use provider-specific specs to declare models and their modalities.",
  "binaryName": "http-chat-completions",
  "installInstructions": "Set MATE_OPENAI_COMPATIBLE_CHAT_ENDPOINT and MATE_OPENAI_COMPATIBLE_API_KEY, or install a provider-specific Mate adapter spec.",
  "spawn": {
    "command": "http-chat-completions",
    "args": [],
    "oneShot": false,
    "loginShell": false,
    "workingDir": "{cwd}"
  },
  "transport": {
    "kind": "http-chat-completions",
    "endpointEnv": "MATE_OPENAI_COMPATIBLE_CHAT_ENDPOINT",
    "apiKeyEnv": "MATE_OPENAI_COMPATIBLE_API_KEY",
    "headers": {
      "X-Mate-Adapter": "openai-compatible-chat"
    },
    "sseDefaultEvent": "chat.completion.chunk",
    "sseDoneEvent": "chat.completion.done"
  },
  "encoding": {
    "mode": "template",
    "framing": "json",
    "attachments": "openaiChatCompletions",
    "userMessage": {
      "template": {
        "model": "{model}",
        "stream": true,
        "messages": [
          {
            "role": "user",
            "content": [
              {
                "type": "text",
                "text": "{prompt}"
              }
            ]
          }
        ]
      }
    }
  },
  "parsing": {
    "framing": "sse",
    "protocol": "chat-completions",
    "discriminator": "type",
    "pluginFallback": false,
    "rules": [
      {
        "match": {
          "equals": "chat.completion.chunk"
        },
        "emit": "streamEvent"
      },
      {
        "match": {
          "equals": "chat.completion.done"
        },
        "emit": "streamEvent"
      },
      {
        "match": {
          "equals": "error"
        },
        "emit": "streamEvent"
      }
    ],
    "reducers": [
      {
        "match": {
          "on": "type",
          "equals": "chat.completion.chunk"
        },
        "emit": "textDelta",
        "fields": {
          "text": "choices[].delta.content"
        }
      },
      {
        "match": {
          "on": "type",
          "equals": "chat.completion.done"
        },
        "emit": "turnEnd"
      },
      {
        "match": {
          "on": "type",
          "equals": "error"
        },
        "emit": "error",
        "fields": {
          "message": "message"
        }
      }
    ]
  },
  "models": [
    {
      "id": "*",
      "label": "Unknown OpenAI-compatible model",
      "hidden": true,
      "inputModalities": [
        "text"
      ],
      "unsupportedImageAttachmentMessage": "This model does not support image attachments. Switch models to send images."
    }
  ],
  "capabilities": {
    "nativeResume": false,
    "perTurnSettings": true,
    "rawTextOutput": false,
    "permissionMetadata": "none",
    "readiness": "immediate"
  },
  "timeouts": {
    "readinessTimeoutMs": 30000,
    "wedgeTimeoutMs": 180000
  }
}
